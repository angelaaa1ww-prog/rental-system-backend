# ─────────────────────────────────────────────
# Rental System Backend — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# Server
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/rental_system?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change_me_to_something_random_and_long

# Admin login credentials
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=your_secure_password

# Allowed frontend origin (for CORS). Comma-separate multiple.
CLIENT_URL=http://localhost:3000

# Africa's Talking SMS gateway
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key
AT_SENDER_ID=RENTALMGR

# Safaricom Daraja / M-Pesa C2B and STK Push
# MPESA_ENV=sandbox for testing, production/live for your real PayBill.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_SHORTCODE=your_paybill_or_sandbox_shortcode
MPESA_PASSKEY=your_lipa_na_mpesa_passkey

# Public HTTPS backend base URL used to build callback URLs.
# Local testing can use an HTTPS tunnel URL.
MPESA_CALLBACK_BASE_URL=https://your-backend.example.com

# Optional overrides. Leave blank unless Safaricom gave you fixed callback URLs.
MPESA_C2B_CONFIRMATION_URL=
MPESA_C2B_VALIDATION_URL=
MPESA_STK_CALLBACK_URL=

# Completed accepts timed-out C2B validation by default.
MPESA_C2B_RESPONSE_TYPE=Completed

# Set true only if you want M-Pesa to reject payments whose account number
# cannot be matched to a tenant/house before money is accepted.
MPESA_C2B_STRICT_VALIDATION=false

# Sandbox C2B simulation default phone.
MPESA_TEST_MSISDN=254708374149
